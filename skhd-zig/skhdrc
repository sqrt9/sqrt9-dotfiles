#---modal bindings---
# allow keys to be rebound while capslock is on
# don't actually turn it on though, just the light
:: default
:: mode_caps
default < f13 ; mode_caps : capslock 1;
mode_caps < f13 ; default : capslock 0;


#---rotate, toggle float, balance windows, opacity---
# (shift + alt = space controls)
# (ctrl + alt  = window controls)
shift + alt - r          : yabai -m space --rotate 270
shift + alt - f          : yabai -m config layout | grep -q "bsp" && yabai -m config layout float || yabai -m config layout bsp
ctrl  + shift - a        : yabai -m window --toggle float --layer below && yabai -m space --balance
mode_caps < sound_up     : transparency_increment 0.1 inc
mode_caps < sound_down   : transparency_increment 0.1 dec

#---move windows around in current space---
ctrl + alt - z : yabai -m window --warp west
ctrl + alt - x : yabai -m window --warp east
ctrl + alt - c : yabai -m window --warp north
ctrl + alt - v : yabai -m window --warp south


#---focus windows---
alt - z : yabai -m window --focus west
alt - x : yabai -m window --focus east
alt - c : yabai -m window --focus north
alt - v : yabai -m window --focus south


#---focus different spaces---
shift + alt - x : yabai -m space --focus $(next_display_or_space_looping -f -s); \
                  echo "f" > $YABAI_LAST_DIRECTION &;
shift + alt - z : yabai -m space --focus $(next_display_or_space_looping -b -s); \
                  echo "b" > $YABAI_LAST_DIRECTION &;


shift + alt - v : yabai -m display --focus "$(next_display_or_space_looping -f -d)"
shift + alt - c : yabai -m display --focus "$(next_display_or_space_looping -b -d)"


#---move window between spaces---
shift + ctrl - x : yabai -m window --space $(next_display_or_space_looping -f -s) --focus; \
                   echo "f" > $YABAI_LAST_DIRECTION &;
shift + ctrl - z : yabai -m window --space $(next_display_or_space_looping -b -s) --focus; \
                   echo "b" > $YABAI_LAST_DIRECTION &;

#---move window between displays---
shift + ctrl - c : yabai -m window --display $(next_display_or_space_looping -b -d) --focus; \
                   echo "b" > $YABAI_LAST_DIRECTION &;
shift + ctrl - v : yabai -m window --display $(next_display_or_space_looping -f -d) --focus; \
                   echo "f" > $YABAI_LAST_DIRECTION &;


#---make window larger/smaller---
# (0x18 - "=" | 0x1B - "-")
shift + alt - 0x18 : yabai -m window yabai --resize right:40:0; \
                     yabai -m window yabai --resize left:40:0; \
                     yabai -m window yabai --resize bottom:40:0; \
                     yabai -m window yabai --resize top:40:0; 

shift + alt - 0x1B : yabai -m window yabai -m window --resize right:-40:0; \
                     yabai -m window yabai -m window --resize left:-40:0; \
                     yabai -m window yabai -m window --resize bottom:-40:0; \
                     yabai -m window yabai -m window --resize top:-40:0; 

#---move spaces---
shift + ctrl + alt - x : yabai -m space --move next; \
                         echo "f" > $YABAI_LAST_DIRECTION &;
shift + ctrl + alt - z : yabai -m space --move prev; \
                         echo "b" > $YABAI_LAST_DIRECTION &;

#---move spaces between displays---
shift + ctrl + alt - v : yabai -m space --display $(next_display_or_space_looping -f -d) --focus
shift + ctrl + alt - c : yabai -m space --display $(next_display_or_space_looping -b -d) --focus


#---despawn spaces---
ctrl + alt - m : destroy_space_and_refocus
ctrl + alt - n : destroy_space_and_refocus -x


#---create space left--- 
# (0x2F - ">" | 0x2B - "<")
ctrl + alt - 0x2F : make_new_space_right; \
                    echo "f" > $YABAI_LAST_DIRECTION &;
ctrl + alt - 0x2B : make_new_space_left; \
                    echo "b" > $YABAI_LAST_DIRECTION &;

#---cycle displays---
shift + alt - 0x2F : rotate_displays -f
shift + alt - 0x2B : rotate_displays -b


#---stop and start service---
shift + ctrl - i : yabai --start-service
shift + ctrl - o : yabai --stop-service


#--save window id---
mode_caps < f1 : echo $(yabai -m query --windows --window | jq -rc .id) > $YABAI_STATE_ONE; \
                 pkill -x alerter; /opt/homebrew/bin/alerter --message 'set 1' --timeout 1 &;
mode_caps < f2 : echo $(yabai -m query --windows --window | jq -rc .id) > $YABAI_STATE_TWO; \
                 pkill -x alerter; /opt/homebrew/bin/alerter --message 'set 2' --timeout 1 &;
mode_caps < f3 : echo $(yabai -m query --windows --window | jq -rc .id) > $YABAI_STATE_THREE; \
                 pkill -x alerter; /opt/homebrew/bin/alerter --message 'set 3' --timeout 1 &;

#---focus window id---
default < f1 : yabai -m window --focus $(< $YABAI_STATE_ONE); \
     pkill -x alerter; /opt/homebrew/bin/alerter --message '1' --timeout 1 &;
default < f2 : yabai -m window --focus $(< $YABAI_STATE_TWO); \
     pkill -x alerter; /opt/homebrew/bin/alerter --message '2' --timeout 1 &;
default < f3 : yabai -m window --focus $(< $YABAI_STATE_THREE); \
     pkill -x alerter; /opt/homebrew/bin/alerter --message '3' --timeout 1 &;


#---space binds---
# use number keys in caps mode to switch space by number
mode_caps < 1 : yabai -m space --focus 1
mode_caps < 2 : yabai -m space --focus 2
mode_caps < 3 : yabai -m space --focus 3
mode_caps < 4 : yabai -m space --focus 4
mode_caps < 5 : yabai -m space --focus 5
mode_caps < 6 : yabai -m space --focus 6


#---mission control---
# (move the cursor slightly after the animation to open the spaces preview)
shift - tab : open -a "Mission Control"; \
              cliclick m:870,50; \
              sleep 0.25; \
              cliclick m:870,51; \