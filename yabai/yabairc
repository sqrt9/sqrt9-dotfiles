#---rebalancing on minimization
# rebuild because sometimes windows like to be 0 size and uncooperative ?
yabai -m signal --add event=window_hidden action="yabai -m space --layout bsp"
yabai -m signal --add event=window_minimized action="yabai -m space --layout bsp"
yabai -m signal --add event=window_destroyed action="yabai -m space --layout bsp"

#---default layout (can be bsp, stack or float)
yabai -m config layout bsp

#---new window spawns to the right if vertical split,
#---or bottom if horizontal split
yabai -m config window_placement second_child

#---setmodifier for clicking and dragging with mouse
yabai -m config mouse_modifier cmd

#---swap windows when dropped in center
yabai -m mouse_drop_action swap
yabai -m config menubar_opacity 0.8

#---focus follows mouse, mouse follows focus, automatically raise windows
yabai -m config focus_follows_mouse off
yabai -m config mouse_follows_focus on

#---padding between windows
yabai -m config top_padding    16
yabai -m config bottom_padding 16
yabai -m config left_padding   16
yabai -m config right_padding  16
yabai -m config window_gap     16

#---toggle opacity settings
yabai -m config window_opacity on

#---stop trying to tile windows while i drag them 
yabai -m config mouse_action1 none
yabai -m config mouse_action2 none

#---window border / mngment settings
yabai -m rule --add app="^Notes$" manage=off
yabai -m rule --add app="^Notion$" manage=off
yabai -m rule --add app="^LuLu$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Stickies$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Find My$" manage=off
yabai -m rule --add app="^Facetime$" manage=off
yabai -m rule --add app="^osascript$" manage=off
yabai -m rule --add app="^System Events$" manage=off
yabai -m rule --add app="^DockDoor$" manage=off
borders active_color=0xffcd4946 inactive_color=0x00000000 width=4.0 style=round ax_focus=on whitelist="Google Chrome,Finder,app_mode_loader,Messages,Facetime,Photos,Music,Spotify,Code,iTerm2,Books,Discord,Notes,Activity Monitor,Podcasts,Find My,Preview,Electron" &

